<!DOCTYPE html>
<html lang="en">
<head>
  <title>Bulb ON/OFF</title>
</head>
<body>
  <script>
    let isOn = false; // track bulb state

    function turnOnOff() {
      let image = document.getElementById("Image");
      if (isOn) {
        image.src = "offmode.jpg";
      } else {
        image.src = "ONbulb.jpg";
      }
      isOn = !isOn; // toggle state
    }
  </script>

  <img id="Image"
    onclick="turnOnOff()"
    src="offmode.jpg"
    alt="Bulb"
    width="200"
  />
  <p>Click on the bulb to turn it ON and OFF</p>
</body>
</html>
